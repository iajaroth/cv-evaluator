# ============================================
# CV Evaluator - Variables de Entorno
# ============================================
# Copiar este archivo a .env y rellenar con tus valores

# OpenAI API Key (requerida)
OPENAI_API_KEY=sk-proj-...

# API Key para proteger el servicio (opcional, se genera automaticamente si no se proporciona)
SERVICE_API_KEY=

# URL del evaluador (para Gmail fetcher)
CV_EVALUATOR_URL=http://localhost:8000

# Base de datos (SQLite por defecto)
DATABASE_URL=sqlite:///./candidates.db

# Directorio para uploads de CVs
UPLOAD_DIR=./uploads
